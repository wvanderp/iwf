  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@types/deep-diff": "^1.0.5",
    "@types/node": "^25.9.2",
    "@types/qs": "^6.15.1",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.19",
    "axios-mock-adapter": "^2.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsdoc": "^63.0.2",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-node": "10.9.2",
    "tsdown": "^0.22.2",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@wmde/wikibase-datamodel-types": "git+https://github.com/wvanderp/WikibaseDataModelTypes.git",
    "axios": "1.17.0",
    "diff-arrays-of-objects": "git+https://github.com/wvanderp/diff-arrays-of-objects.git",
    "qs": "^6.15.2",
    "uuid": "^14.0.0",
    "wikidata-properties": "git+https://github.com/wvanderp/wikidata-properties.git"
  },
  "scripts": {
    "build": "tsdown",
    "docs": "typedoc --out docs src/index.ts",
    "lint": "npm-run-all -c -s tsc eslint",
    "tsc": "tsc --noEmit",
    "eslint": "eslint src/ tests/integration tests/unit",
    "prepublishOnly": "npm run build",
    "test": "vitest run tests/unit --coverage",
    "test:all": "vitest run --coverage",
    "clean": "rimraf lib/ .nyc_output/ coverage/ docs/"
