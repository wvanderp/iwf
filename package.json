    "eslint-plugin-sonarjs": "^4.0.1",
    "eslint-plugin-unicorn": "^53.0.0",
    "globals": "^17.4.0",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "source-map-support": "^0.5.21",
    "ts-node": "10.9.2",
    "tsdown": "^0.21.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@wmde/wikibase-datamodel-types": "git+https://github.com/wvanderp/WikibaseDataModelTypes.git",
    "axios": "1.13.6",
    "diff-arrays-of-objects": "git+https://github.com/wvanderp/diff-arrays-of-objects.git",
    "qs": "^6.15.0",
    "uuid": "^13.0.0",
    "wikidata-properties": "git+https://github.com/wvanderp/wikidata-properties.git"
  },
  "scripts": {
    "build": "tsdown",
    "docs": "typedoc --out docs src/index.ts",
    "lint": "npm-run-all -c -s tsc eslint",
    "tsc": "tsc --noEmit",
    "eslint": "eslint src/ tests/integration tests/unit",
    "prepublishOnly": "npm run build",
    "test": "vitest run tests/unit --coverage",
    "test:all": "vitest run --coverage",
    "clean": "rimraf lib/ .nyc_output/ coverage/ docs/"
