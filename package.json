{
  "name": "iwf",
  "version": "0.1.1",
  "description": "improved wikidata format",
  "author": "wvdp",
  "license": "MIT",
  "keywords": [
    "wikidata",
    "wikipedia"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wvanderp/iwf.git"
  },
  "homepage": "https://wvanderp.github.io/iwf/",
  "main": "./lib/index.js",
